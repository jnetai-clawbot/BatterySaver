<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:paddingBottom="48dp">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="App Icon"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Battery Saver"
            android:textSize="28sp"
            android:textColor="@color/on_background"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Version 1.0.0"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingTop="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/made_by"
            android:textSize="14sp"
            android:textColor="@color/accent"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Battery Saver monitors your device battery health in real-time. It alerts you with sound and vibration when:\n\n• Battery level drops below your set threshold\n• Battery temperature exceeds safe limits\n• Unstable charging voltage or current is detected\n\nThe app runs as a background service and can auto-start on boot to ensure continuous protection."
            android:textSize="14sp"
            android:textColor="@color/on_background"
            android:lineSpacingExtra="4dp"
            android:paddingBottom="24dp" />

        <Button
            android:id="@+id/btnCheckUpdates"
            style="@style/ButtonPrimary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/check_updates"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnShareApp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/share_app"
            android:textSize="16sp"
            android:textColor="@color/accent"
            android:strokeColor="@color/accent" />

    </LinearLayout>

</ScrollView>
